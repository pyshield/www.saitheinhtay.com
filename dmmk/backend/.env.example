# Server
PORT=3000
NODE_ENV=development

# Set true to run API without an RPC listener (e.g. Docker API-only mode)
# SKIP_BLOCKCHAIN=true

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=dmmk
DB_PASSWORD=changeme
DB_NAME=dmmk_pay
DB_CONNECTION_LIMIT=10

# Blockchain (Polygon, Base, or other EVM L2)
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ROUTER_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DMMK_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
DMMK_DECIMALS=18

# Optional: websocket RPC improves event listener reliability
# WS_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Listener tuning
LISTENER_START_BLOCK=latest
LISTENER_POLLING_INTERVAL_MS=4000

# P2P agent matching
AGENT_MAX_ACTIVE_CASHOUTS=5
