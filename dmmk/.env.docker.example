# Copy to .env at repo root: cp .env.docker.example .env

# MySQL
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_HOST_PORT=3306
DB_USER=dmmk
DB_PASSWORD=changeme
DB_NAME=dmmk_pay

# Backend / blockchain
# API-only stack (no local chain): keep SKIP_BLOCKCHAIN=true and set RPC_URL + ROUTER_CONTRACT_ADDRESS
SKIP_BLOCKCHAIN=true
RPC_URL=https://polygon-rpc.com
ROUTER_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DMMK_TOKEN_ADDRESS=

# Full local stack: docker compose --profile blockchain up --build
# SKIP_BLOCKCHAIN=false
# (contract addresses are loaded from the deployer volume automatically)

BACKEND_HOST_PORT=3000
CHAIN_HOST_PORT=8545
FRONTEND_HOST_PORT=8080

VITE_MERCHANT_ID=1
VITE_AGENT_ID=2
